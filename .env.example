# Dispatchr configuration

# LLM_PROVIDER: "mock"  -> deterministic, no API key needed (used by the demo + CI evals)
#               "openai" -> real LLM via any OpenAI-compatible API (OpenAI, OpenRouter, local)
LLM_PROVIDER=mock

# Only used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
